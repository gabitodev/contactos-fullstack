---
import CreateContact from '../features/contacts/CreateContact.astro';
import PageLayout from '../layout/PageLayout.astro';
import ContactItem from './ContactItem.astro';
---

<>
  <ul
    id="contacts-list"
    class="flex-1 m-0 p-2 list-none overflow-auto flex flex-col gap-8 rounded-md border border-gray-400 w-full md:w-[70%] lg:w-[50%]"
  >
  </ul>
  <ContactItem />
</>

<script>
  import { showToast } from '../../components/notification/notification';
  import contactsService, { contactStore } from './contactService';
  import { updateContactSchema } from './schemas';
  import { authStore } from '../auth/auth.service';

  const contactsList = document.querySelector('#contacts-list');
  const contactItemTemplate = document.querySelector('#template-contact-item');

  // Actualiza los colores y el texto de error usando clases de Tailwind
  const handleStateInput = (input, isInvalid, textError) => {
    const helperText = input.nextElementSibling;
    helperText.innerHTML = textError;

    if (!input.value) {
      input.classList.remove('outline-red-500', 'outline-green-500');
      input.classList.add('outline-gray-400');
      helperText.classList.add('hidden');
    } else if (isInvalid) {
      input.classList.add('outline-red-500');
      input.classList.remove('outline-green-500', 'outline-gray-400');
      helperText.classList.remove('hidden');
    } else {
      input.classList.add('outline-green-500');
      input.classList.remove('outline-red-500', 'outline-gray-400');
      helperText.classList.add('hidden');
    }
  };

  const handleInputEditing = (inputs) => {
    inputs.forEach((input) => {
      input.removeAttribute('readonly');
      input.classList.add('outline', 'outline-gray-400');
      input.classList.remove('outline-none');
    });
  };

  const handleDeleteContact = (id) => {
    contactsService.deleteContact(id);
    showToast({ text: `Contacto "${id}" eliminado exitosamente`, type: 'success' });
  };

  const handleUpdateContact = (contact, contacts, liElements) => {
    const { nameInput, phoneInput } = liElements;

    // Parte 1. Cambiar el estado del editando
    const updatedContact = { ...contact, isEditing: !contact.isEditing };
    const updatedContacts = contacts.map((c) => (c.id === contact.id ? updatedContact : c));

    // Parte2: El editando
    if (!contact.isEditing) {
      contactStore.set(updatedContacts);
      return;
    }

    // 1. Validar
    const { success, error } = updateContactSchema.safeParse({
      name: nameInput.value,
      phone: phoneInput.value,
    });

    const fieldErrors = error?.flatten()?.fieldErrors;
    const isInvalidName = fieldErrors?.name ? true : false;
    const isInvalidPhone = fieldErrors?.phone ? true : false;
    handleStateInput(nameInput, isInvalidName, fieldErrors?.name?.[0]);
    handleStateInput(phoneInput, isInvalidPhone, fieldErrors?.phone?.[0]);

    if (!success) return;

    // 2. Guardar
    contactsService.updateContact(contact.id, {
      name: nameInput.value,
      phone: phoneInput.value,
    });

    showToast({ text: `Contacto "${nameInput.value}" actualizado exitosamente`, type: 'success' });
  };

  contactStore.listen((contacts) => {
    contactsList.innerHTML = '';
    contacts.forEach((contact) => {
      const li = contactItemTemplate.content.cloneNode(true).children[0];
      const liElements = {
        nameInput: li.querySelector('.contacts-list-item-name-input'),
        phoneInput: li.querySelector('.contacts-list-item-phone-input'),
        deleteBtn: li.querySelector('.delete-btn'),
        editBtn: li.querySelector('.edit-btn'),
      };

      const { nameInput, phoneInput, editBtn, deleteBtn } = liElements;

      li.id = contact.id;
      nameInput.value = contact.name;
      phoneInput.value = contact.phone;

      if (contact.isEditing) {
        handleInputEditing([nameInput, phoneInput]);
        editBtn.innerHTML = '<ion-icon name="checkmark-outline"></ion-icon>';
      }

      deleteBtn.addEventListener('click', () => handleDeleteContact(contact.id));
      editBtn.addEventListener('click', () => handleUpdateContact(contact, contacts, liElements));

      contactsList.append(li);
    });
  });

  // Carga inicial
  authStore.listen((auth) => {
    if (!auth) return;
    contactsService.getContactsFromServer();
  });
</script>
